---
apiVersion: gateway.networking.k8s.io/v1
kind: Gateway
metadata:
  name: shared-gtw
  namespace: evocloud-ns
  annotations:
    cert-manager.io/cluster-issuer: evoidp-issuer #needed for automatic certs generation by cert-manager
spec:
  gatewayClassName: cilium
  addresses:
    - type: IPAddress
      value: {{ gtw_lb_ip }}
  listeners:
    - name: http-listener
      hostname: evoapp.{{ domain_tld }}
      port: 80
      protocol: HTTP
      allowedRoutes:
        namespaces:
          from: All

    - name: https-listener
      hostname: evoapp.{{ domain_tld }}
      port: 443
      protocol: HTTPS
      allowedRoutes:
        namespaces:
          from: All
      tls:
        mode: Terminate #Passthrough mode is not supported yet.
        certificateRefs:
          - name: shared-gtw-tls
            kind: Secret            #https://github.com/cert-manager/cert-manager/issues/5610
            namespace: evocloud-ns  #Automatic cert provisioning will fail if the requested cert is in a different namespace than the Gateway.
